# =============================================================================
# LaporKita Environment Variables Example
# Copy ke .env dan isi dengan credentials sebenarnya. JANGAN commit .env!
# =============================================================================

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# --- DOKU Sandbox (Payment Provider Indonesia) ---
# Get from https://sandbox.doku.com → Integration → API Keys
DOKU_CLIENT_ID=BRN-xxxxx
DOKU_API_KEY=doku_key_sandbox_xxxxx
DOKU_SECRET_KEY=SK-xxxxx
# Base64 encoded "api_key:" (with trailing colon)
DOKU_AUTHORIZATION_BASE64=base64_encoded_value
DOKU_BASE_URL=https://api-sandbox.doku.com
DOKU_MCP_URL=https://api-sandbox.doku.com/doku-mcp-server/mcp

# --- Mem9 (Persistent Agent Memory) ---
# Auto-provisioned via Claude Code plugin (mem9@mem9). Fallback manual:
MEM9_API_KEY=
MEM9_BASE_URL=https://api.mem9.ai

# --- Solana Devnet (Web3 Reward Layer) ---
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_API_KEY=
# Backend mint authority wallet (generated via scripts/setup_solana.py)
SOLANA_MINT_AUTHORITY_KEYPAIR_PATH=.solana-id-keypair.json
LAPORPOINTS_MINT_ADDRESS=

# --- Fonnte (WhatsApp Indonesia API) ---
# https://fonnte.com — opsional, fallback Telegram
FONNTE_TOKEN=
TELEGRAM_BOT_TOKEN=

# --- FastAPI ---
APP_PORT=8000
APP_HOST=0.0.0.0
APP_ENV=development
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./laporkita.db

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- LaporKita Business Rules ---
# Verified report earn rate
EARN_LAPORPOINTS_PER_VERIFIED_REPORT=10
# Threshold ke auto-mint as SPL token (per LaporPoints accumulated)
MINT_THRESHOLD_LAPORPOINTS=10
# Redemption rate (1 LPT = X IDR)
REDEMPTION_RATE_IDR_PER_LPT=1000
