{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/main.py": {
      "runtime": "@vercel/python@4.3.0",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/main" }
  ]
}
